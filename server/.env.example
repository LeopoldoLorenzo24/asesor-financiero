# === CEDEAR ADVISOR - CONFIGURACIÓN ===

# Tu API Key de Anthropic (obligatoria para el análisis IA)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Puerto del servidor (default 3001)
PORT=3001

# Origen permitido para CORS (URL de tu frontend)
CLIENT_ORIGIN=http://localhost:5173

# Cache TTL en segundos (default 300 = 5 minutos)
CACHE_TTL=300
