# === CEDEAR ADVISOR - CONFIGURACION ===

# 1. ANTHROPIC (opcional, solo para rutas de IA)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. SERVIDOR
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false
CACHE_TTL=300
RATE_LIMIT_FAIL_OPEN=false

# 3. TURSO (opcional: si no se define usa archivo local)
TURSO_URL=libsql://tu-db-usuario.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# 4. AUTH
# JWT_SECRET: minimo 32 caracteres aleatorios
JWT_SECRET=cambia-esto-por-un-string-aleatorio-de-al-menos-32-caracteres
# AUTH_PASSWORD: password larga y unica para login directo
AUTH_PASSWORD=una-password-larga-y-unica-con-mayuscula-numero-y-simbolo
# Email permitido para tu usuario
AUTH_ALLOWED_EMAIL=tu-email@ejemplo.com
# Solo activar en el primer alta si queres habilitar /auth/register
ALLOW_INITIAL_REGISTER=false
AUTH_MIN_PASSWORD_LENGTH=12
# Opcional: reducir duracion del token
AUTH_TOKEN_TTL_DAYS=7

# 5. TELEGRAM BOT (opcional - alertas)
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=12345678

# 6. FINNHUB (opcional - datos extra)
FINNHUB_API_KEY=cqxxxxxxxxxxxxxxxx

# 7. FEATURE FLAGS (opcional)
# ENABLE_RATE_LIMIT=true
# ENABLE_TELEGRAM_ALERTS=true
# ENABLE_ML_AUTO_COLLECT=true
# ENABLE_TRADING_SIGNALS=true
