# === CEDEAR ADVISOR - CONFIGURACIÓN ===

# Tu API Key de Anthropic (obligatoria para el análisis IA)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Puerto del servidor (default 3001)
PORT=3001

# Origen permitido para CORS (URL de tu frontend)
CLIENT_ORIGIN=http://localhost:5173

# Cache TTL en segundos (default 300 = 5 minutos)
CACHE_TTL=300

# === Turso (DB en la nube, gratis) ===
# URL de tu base Turso (libsql://tu-db-tu-usuario.turso.io)
# Sin esto, usa SQLite local en ./data/cedear-advisor.db
TURSO_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=tu-token-aqui

# Contraseña fija para login (si se omite, usa hash de la DB)
AUTH_PASSWORD=tu-contraseña-aqui
