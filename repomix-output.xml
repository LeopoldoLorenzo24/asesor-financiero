            </div>
          </div>
        )}

        <div style={{ ...S.card, marginBottom: 20, border: `1px solid ${T.green}15` }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
            <div>
              <div style={S.label}>Análisis IA Completo</div>
