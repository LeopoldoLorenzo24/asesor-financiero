            {[{ l: "RSI", v: tech?.indicators?.rsi }, { l: "MACD", v: tech?.indicators?.macd?.macd }, { l: "SMA 20", v: tech?.indicators?.sma20?.toFixed(2) }, { l: "SMA 50", v: tech?.indicators?.sma50?.toFixed(2) }, { l: "ATR", v: tech?.indicators?.atr }].map((it, i) => (
